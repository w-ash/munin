GOOGLE_MAPS_API_KEY=your-key-here
# Compliant User-Agent contact per Wikimedia Foundation User-Agent Policy
# (March 2026 stricter CDN check) and Nominatim usage policy. Used by
# cover_image (Wikimedia Commons downloads) and geocode (Overpass +
# Nominatim). Hard-fail if missing — silent fallback got the script
# CDN-blocked before.
VAULT_CONTACT_EMAIL=you@example.com
# Path to a Google service-account JSON key, stored in the shared key dir
# (~/.config/gcp/, chmod 700, outside this repo and iCloud — see its README).
# Used by the `sheets` module to read/write Google Sheets. Share each target
# sheet with the service account's client_email (Editor for writes, Viewer for
# read-only). A leading ~ is expanded.
GOOGLE_SHEETS_SA_JSON=~/.config/gcp/vault-sheets-sa.json
# The `docs` tool (Google Docs read + in-place edits) reuses the Sheets service
# account by default. Set this only if Docs should use a different key; unset, it
# falls back to GOOGLE_SHEETS_SA_JSON. Share each target doc with the client_email.
GOOGLE_DOCS_SA_JSON=~/.config/gcp/vault-sheets-sa.json
# OAuth-user mode for `docs create` / `docs template` (owned-file creation, which
# the service account can't do). GOOGLE_OAUTH_CLIENT_JSON points at a Desktop OAuth
# client's secrets; run `vault-tool docs auth-login` once to write the refresh
# token to GOOGLE_OAUTH_TOKEN_JSON. Only needed for the creation tier.
GOOGLE_OAUTH_CLIENT_JSON=~/.config/gcp/oauth-client.json
GOOGLE_OAUTH_TOKEN_JSON=~/.config/gcp/docs-oauth.json

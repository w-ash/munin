GOOGLE_MAPS_API_KEY=your-key-here
# Compliant User-Agent contact per Wikimedia Foundation User-Agent Policy
# (March 2026 stricter CDN check) and Nominatim usage policy. Used by
# cover_image (Wikimedia Commons downloads) and geocode (Overpass +
# Nominatim). Hard-fail if missing — silent fallback got the script
# CDN-blocked before.
VAULT_CONTACT_EMAIL=you@example.com
